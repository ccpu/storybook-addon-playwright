{
  "name": "storybook-addon-playwright",
  "version": "7.0.2",
  "packageManager": "pnpm@10.25.0",
  "description": "An addon to visually test the stories in the multiple browsers within storybook environment",
  "author": "m.doaie <mdoaie@yahoo.co.uk>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccpu/storybook-addon-playwright.git"
  },
  "keywords": [
    "playwright",
    "browser",
    "e2e",
    "storybook",
    "addon",
    "cross browser testing",
    "end-to-end",
    "test",
    "testing",
    "visual",
    "visual testing",
    "screenshot",
    "storybook-addon"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.mjs",
      "require": "./dist/ai/index.js"
    },
    "./configs": {
      "types": "./configs.d.ts",
      "require": "./configs.js"
    },
    "./middleware": {
      "types": "./middleware.d.ts",
      "require": "./middleware.js"
    },
    "./register": {
      "import": "./dist/register.mjs",
      "require": "./register.js"
    },
    "./typings/global": "./typings/global.d.ts",
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "types": "",
  "bin": {
    "storybook-addon-playwright": "./dist/cli.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "ai.d.ts",
    "ai.js",
    "assets",
    "configs.d.ts",
    "configs.js",
    "dist",
    "middleware.d.ts",
    "middleware.js",
    "register.js",
    "typings/global.d.ts"
  ],
  "engines": {
    "node": ">= 24.15.0",
    "pnpm": ">= 10.25.0"
  },
  "scripts": {
    "storybook": "pnpm run clean && pnpm exec tsx .storybook/start-dev.ts",
    "generate:playwright:action-schema": "pnpm exec tsx scripts/playwright/generate-action-schema.ts",
    "generate:playwright:all-schema": "pnpm exec tsx scripts/playwright/generate-all-schema.ts",
    "generate:playwright:schema": "pnpm run generate:playwright:all-schema",
    "changeset": "changeset",
    "prepare": "husky",
    "clean": "rimraf coverage dist tmp",
    "build": "pnpm run clean && tsup",
    "build:watch": "tsup --watch",
    "format:fix": "prettier --write .",
    "lint:fix": "eslint src __mocks__ test/manual-mocks test/configs stories setupTests.ts middleware.d.ts configs.d.ts .storybook/setup-playwright.js --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "tsc:watch": "tsc -w",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "node ./scripts/test.mjs",
    "check:all": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "migrate:props-to-args": "pnpm exec tsx src/cli.ts migrate props-to-args",
    "test:coverage": "node ./scripts/test.mjs --coverage",
    "test:watch": "vitest",
    "prepack": "pnpm run lint && pnpm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dom-utils/selector-path": "^1.0.3",
    "@ebay/nice-modal-react": "^1.2.13",
    "@material-ui/core": "^4.12.4",
    "@material-ui/icons": "^4.11.3",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "@pixpilot/dev-config": "^3.20.0",
    "@pixpilot/dom": "^0.0.1",
    "@pixpilot/hash": "^0.2.0",
    "@pixpilot/object": "^2.4.2",
    "@storybook/components": "^8.6.18",
    "@storybook/core": "^8.6.18",
    "@storybook/core-events": "^8.6.18",
    "@storybook/icons": "^2.0.2",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/theming": "^8.6.18",
    "@tanstack/react-query": "^5.100.10",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "^11.17.0",
    "array-move": "^3.0.1",
    "clsx": "^2.1.1",
    "deepmerge": "^4.3.1",
    "fast-deep-equal": "^3.1.3",
    "fast-glob": "^3.3.3",
    "hash-sum": "^2.0.0",
    "jest-image-snapshot": "^6.5.2",
    "join-images": "^1.4.0",
    "jsonfile": "^6.2.1",
    "lodash": "^4.18.1",
    "nanoid": "^5.1.11",
    "normalize-url": "9.0.0",
    "object-path-immutable": "^4.1.2",
    "p-limit": "7.3.0",
    "playwright": "~1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-view": "^1.21.3",
    "react-map-interaction": "^2.1.0",
    "react-selecto": "^1.26.3",
    "react-split-pane": "^3.2.0",
    "react-use": "^17.6.0",
    "reinspect": "^1.1.0",
    "sharp": "^0.34.5",
    "sonner": "2.0.7",
    "tinycolor2": "^1.6.0",
    "ts-to-json": "^1.8.3",
    "typescript": "~5.9.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@pixpilot/eslint-config-react": "^0.5.1",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@tippyjs/react": "^4.2.6",
    "@types/enzyme": "^3.10.19",
    "@types/jsonfile": "^6.1.4",
    "@types/node": "^25.7.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/sharp": "^0.32.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.8.0",
    "babel-loader": "^8.2.3",
    "enzyme": "^3.11.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jest-fetch-mock": "^3.0.3",
    "jest-mock-console": "^2.0.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "msw": "^2.14.6",
    "msw-trpc": "^2.0.1",
    "prettier": "^3.8.3",
    "react-draggable": "^4.5.0",
    "rimraf": "^6.1.3",
    "storybook": "^8.6.17",
    "storybook-dark-mode": "^4.0.2",
    "tslib": "2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.6"
  },
  "storybook": {
    "displayName": "Playwright"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "enzyme>cheerio": "1.0.0-rc.12"
    }
  },
  "resolutions": {
    "@types/react": "17.0.16",
    "@types/react-dom": "17.0.16"
  }
}
