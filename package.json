{
  "name": "storybook-addon-playwright",
  "version": "5.0.0-rc.37",
  "packageManager": "pnpm@10.25.0",
  "description": "An addon to visually test the stories in the multiple browsers within storybook environment",
  "author": "m.doaie <mdoaie@yahoo.co.uk>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccpu/storybook-addon-playwright.git"
  },
  "keywords": [
    "playwright",
    "browser",
    "e2e",
    "storybook",
    "addon",
    "cross browser testing",
    "end-to-end",
    "test",
    "testing",
    "visual",
    "visual testing",
    "screenshot",
    "storybook-addon"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "types": "",
  "bin": {
    "storybook-addon-playwright": "./dist/cli.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "assets",
    "configs.d.ts",
    "configs.js",
    "dist",
    "middleware.d.ts",
    "middleware.js",
    "register.js",
    "typings/global.d.ts"
  ],
  "engines": {
    "node": ">= 24.15.0",
    "pnpm": ">= 10.25.0"
  },
  "scripts": {
    "storybook": "pnpm run clean && pnpm exec tsx .storybook/start-dev.ts",
    "changeset": "changeset",
    "prepare": "husky",
    "clean": "rimraf coverage dist/* tmp",
    "build": "pnpm run clean && tsup",
    "build:watch": "tsup --watch",
    "format:fix": "prettier --write .",
    "lint:fix": "eslint src __mocks__ test/manual-mocks test/configs stories setupTests.ts middleware.d.ts configs.d.ts .storybook/setup-playwright.js --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "tsc:watch": "tsc -w",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "node ./scripts/test.mjs",
    "check:all": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "migrate:props-to-args": "pnpm exec tsx src/cli.ts migrate props-to-args",
    "test:coverage": "node ./scripts/test.mjs --coverage",
    "test:watch": "vitest",
    "prepack": "pnpm run lint && pnpm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dom-utils/selector-path": "^1.0.3",
    "@ebay/nice-modal-react": "^1.2.13",
    "@material-ui/core": "^4.12.4",
    "@material-ui/icons": "^4.11.3",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "@pixpilot/dev-config": "^3.17.0",
    "@pixpilot/dom": "^0.0.1",
    "@pixpilot/hash": "^0.2.0",
    "@pixpilot/object": "^2.4.2",
    "@storybook/components": "^8.6.18",
    "@storybook/core": "^8.6.18",
    "@storybook/core-events": "^8.6.18",
    "@storybook/icons": "^2.0.2",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/preview-api": "^8.6.18",
    "@storybook/theming": "^8.6.18",
    "@tanstack/react-query": "^5.100.9",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "^11.17.0",
    "array-move": "^3.0.1",
    "body-parser": "^1.19.0",
    "clsx": "^1.1.1",
    "deepmerge": "^4.2.2",
    "fast-deep-equal": "^3.1.3",
    "fast-glob": "^3.2.4",
    "hash-sum": "^2.0.0",
    "ip": "^1.1.5",
    "jest-image-snapshot": "^4.5.1",
    "join-images": "^1.1.5",
    "jsonfile": "^6.1.0",
    "lodash": "^4.17.20",
    "nanoid": "^3.1.18",
    "normalize-url": "6.1.0",
    "object-hash": "^2.0.3",
    "object-path-immutable": "^4.1.1",
    "p-limit": "3.1.0",
    "playwright": "~1.59.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-json-view": "^1.19.1",
    "react-map-interaction": "^2.0.0",
    "react-selecto": "^1.22.1",
    "react-split-pane": "^3.2.0",
    "react-use": "^17.2.4",
    "reinspect": "^1.1.0",
    "sharp": "^0.34.2",
    "sonner": "2.0.7",
    "tinycolor2": "^1.4.2",
    "ts-to-json": "^1.8.3",
    "typescript": "~5.9.3",
    "webpack-sources": "^3.2.3",
    "zod": "^4.3.6",
    "zustand": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.4",
    "@babel/preset-react": "^7.16.0",
    "@babel/preset-typescript": "^7.16.0",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@pixpilot/eslint-config-react": "^0.5.1",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/router": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^12.1.5",
    "@testing-library/react-hooks": "^7.0.2",
    "@tippyjs/react": "^4.2.0",
    "@types/enzyme": "^3.10.8",
    "@types/express": "^4.17.9",
    "@types/glob": "^7.1.3",
    "@types/jsonfile": "^6.0.0",
    "@types/node": "^16.4.13",
    "@types/react": "17.0.16",
    "@types/react-dom": "17.0.16",
    "@types/sharp": "^0.28.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.16",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.6.5",
    "babel-loader": "^8.2.3",
    "enzyme": "^3.11.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jest-fetch-mock": "^3.0.3",
    "jest-mock-console": "^1.2.3",
    "jiti": "^2.7.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.2",
    "msw-trpc": "^2.0.1",
    "prettier": "^2.2.0",
    "react-draggable": "^4.4.3",
    "rimraf": "^3.0.2",
    "storybook": "^8.6.17",
    "storybook-dark-mode": "^4.0.2",
    "tslib": "2.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  },
  "storybook": {
    "displayName": "Playwright"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "enzyme>cheerio": "1.0.0-rc.12"
    }
  },
  "resolutions": {
    "@types/react": "17.0.16",
    "@types/react-dom": "17.0.16"
  }
}
