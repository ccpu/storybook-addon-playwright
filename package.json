{
  "name": "storybook-addon-playwright",
  "version": "4.21.0",
  "description": "An addon to visually test the stories in the multiple browsers within storybook environment",
  "author": "m.doaie <mdoaie@yahoo.co.uk>",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">= 20.19.0",
    "pnpm": ">= 10.25.0"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "types": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccpu/storybook-addon-playwright.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "assets",
    "typings/global.d.ts",
    "register.js",
    "configs.js",
    "configs.d.ts",
    "middleware.d.ts",
    "middleware.js",
    "preset.js"
  ],
  "keywords": [
    "playwright",
    "browser",
    "e2e",
    "storybook",
    "addon",
    "cross browser testing",
    "end-to-end",
    "test",
    "testing",
    "visual",
    "visual testing",
    "screenshot",
    "storybook-addon"
  ],
  "scripts": {
    "start:storybook": "pnpm run clean && pnpm exec tsx .storybook/start-dev.ts",
    "changeset": "changeset",
    "prepare": "husky",
    "clean": "rimraf coverage dist/* tmp",
    "build": "pnpm run clean ",
    "format:fix": "prettier --write .",
    "lint:fix": "eslint src __mocks__ test/manual-mocks test/configs stories setupTests.ts middleware.d.ts configs.d.ts --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit -p tsconfig.release.json",
    "watch": "tsc -w -p tsconfig.release.json",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "node ./scripts/test.mjs",
    "test:coverage": "node ./scripts/test.mjs --coverage",
    "test:watch": "vitest",
    "prepack": "pnpm run lint && pnpm run build"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.4",
    "@babel/preset-react": "^7.16.0",
    "@babel/preset-typescript": "^7.16.0",
    "@changesets/cli": "^2.29.7",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^12.1.5",
    "@testing-library/react-hooks": "^7.0.2",
    "@tippyjs/react": "^4.2.0",
    "@types/enzyme": "^3.10.8",
    "@types/express": "^4.17.9",
    "@types/glob": "^7.1.3",
    "@types/jsonfile": "^6.0.0",
    "@types/node": "^16.4.13",
    "@types/react": "17.0.16",
    "@types/react-dom": "17.0.16",
    "@types/sharp": "^0.28.5",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.13",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.6.5",
    "babel-loader": "^8.2.3",
    "enzyme": "^3.11.0",
    "eslint": "^8.3.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-sort-keys-fix": "^1.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "jest-fetch-mock": "^3.0.3",
    "jest-mock-console": "^1.2.3",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.2",
    "msw-trpc": "^2.0.1",
    "prettier": "^2.2.0",
    "react-draggable": "^4.4.3",
    "rimraf": "^3.0.2",
    "storybook": "^8.6.17",
    "storybook-dark-mode": "^4.0.2",
    "tslib": "2.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "webpack": "5.74.0",
    "webpack-virtual-modules": "0.4.4"
  },
  "resolutions": {
    "@types/react": "17.0.16",
    "@types/react-dom": "17.0.16"
  },
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dom-utils/selector-path": "^1.0.3",
    "@material-ui/core": "^4.12.4",
    "@material-ui/icons": "^4.11.3",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "@storybook/components": "^8.6.18",
    "@storybook/core-events": "^8.6.18",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/preview-api": "^8.6.18",
    "@storybook/theming": "^8.6.18",
    "@tanstack/react-query": "^5.80.3",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "11.16.0",
    "@trpc/server": "^11.16.0",
    "add": "^2.0.6",
    "array-move": "^3.0.1",
    "body-parser": "^1.19.0",
    "clsx": "^1.1.1",
    "deepmerge": "^4.2.2",
    "fast-deep-equal": "^3.1.3",
    "fast-glob": "^3.2.4",
    "hash-sum": "^2.0.0",
    "ip": "^1.1.5",
    "jest-image-snapshot": "^4.5.1",
    "join-images": "^1.1.5",
    "jsonfile": "^6.1.0",
    "lodash": "^4.17.20",
    "nanoid": "^3.1.18",
    "normalize-url": "6.1.0",
    "notistack": "^1.0.1",
    "object-hash": "^2.0.3",
    "object-path-immutable": "^4.1.1",
    "p-limit": "3.1.0",
    "playwright": "~1.17.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-json-view": "^1.19.1",
    "react-map-interaction": "^2.0.0",
    "react-selecto": "^1.22.1",
    "react-split-pane": "^0.1.92",
    "react-toastify": "^11.1.0",
    "react-use": "^17.2.4",
    "reinspect": "^1.1.0",
    "sharp": "^0.30.4",
    "tinycolor2": "^1.4.2",
    "ts-to-json": "^1.8.3",
    "typescript": "~5.1.3",
    "webpack-sources": "^3.2.3",
    "zod": "^4.3.6",
    "zustand": "^4.3.6"
  },
  "storybook": {
    "displayName": "Playwright"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "enzyme>cheerio": "1.0.0-rc.12"
    }
  }
}
