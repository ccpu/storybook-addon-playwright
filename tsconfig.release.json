{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "removeComments": false
  },
  "include": ["src/**/*", "typings/**/*"],
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "test/**/*",
    "**/__tests__/*",
    "**/__mocks__/*"
  ]
}
